# ───────────────────────────────────────────────────────────────────
# REQUIRED: point at any OpenAI-compatible endpoint. Default pattern
# is the host's Ollama:
#   OLLAMA_BASE_URL=http://host.docker.internal:11434/v1   (Linux/Mac/Win)
#   OLLAMA_BASE_URL=http://192.168.1.x:11434/v1            (LAN IP)
#
# To use the bundled demo-ollama service instead, set:
#   OLLAMA_BASE_URL=http://demo-ollama:11434/v1
# and start the demo with `--profile local-models` to bring up the
# bundled GPU Ollama service.
# ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=

# REQUIRED: model the demo will call. Must already be pulled in your
# Ollama instance: `ollama pull <name>`.
LLM_MODEL=

# Optional HF token for downloading gated models on the bundled vLLM
# container that specter spins up via the Docker socket.
HF_TOKEN=

# Optional vLLM endpoint (only used if you spin up vLLM separately).
# VLLM_BASE_URL=http://demo-vllm:8000

# HOST path to the HuggingFace / vLLM models cache. Required ONLY if
# you use the vLLM benchmarking flow — specter spawns sibling vllm
# containers via the docker socket and bind-mounts this directory in
# as /root/.cache/huggingface. Must be an absolute host path because
# the docker daemon (running on the host) resolves it, not specter.
# Example:
#   VLLM_MODELS_DIR=/home/you/data/vllm-models
# VLLM_MODELS_DIR=

# ───────────────────────────────────────────────────────────────────
# Host port mappings.
# ───────────────────────────────────────────────────────────────────
APP_PORT=8080
REDIS_HOST_PORT=6379
OLLAMA_HOST_PORT=11434

# ───────────────────────────────────────────────────────────────────
# BYO overrides — uncomment + set + start with the byo override.
#   docker compose -f docker-compose.yml -f docker-compose.byo.yml up -d
# ───────────────────────────────────────────────────────────────────
# REDIS_URL=redis://redis.example.com:6379/15

# ───────────────────────────────────────────────────────────────────
# Optional Langfuse observability (BYO only — not bundled).
# ───────────────────────────────────────────────────────────────────
# LANGFUSE_HOST=http://my-langfuse:3000
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...

# ───────────────────────────────────────────────────────────────────
# Optional HTTPS reverse proxy (--profile proxy).
# ───────────────────────────────────────────────────────────────────
DEMO_HOSTNAME=localhost
HTTP_PORT=8081
HTTPS_PORT=8443
